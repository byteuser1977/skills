{"name": "colamd-themes", "version": "2.0.0", "description": "ColaMD 主题生成与管理技能 (v2.0.0)，基于 @bytechain.cn/colamd-themes npm 包。支持从 URL、DOCX、PDF 提取视觉格式并转换为符合 v3.0 范式的 CSS 主题文件，以及将 Markdown 导出为 HTML/PDF。v2.0 新增：设计约束规范(DC) - 5大核心约束(字体/字号/配色/扩展背景/打印同步)。",
  "author": "ColaMD Community",
  "license": "MIT",
  "npm_package": "@bytechain.cn/colamd-themes",
  "dependencies": {
    "node": ">=18"
  },
  "features": {
    "v0_3_2": {
      "security": {
        "ssrf_protection": "URL提取器验证协议白名单，阻止私有网络访问",
        "input_validation": "CSS文件验证扩展名、大小限制（最大1MB）、内容有效性",
        "error_handling": "结构化错误代码(CLIError + ErrorCode)，便于调试"
      },
      "performance": {
        "async_io": "非阻塞文件操作，提升批量导出响应性",
        "template_cache": "LRU缓存策略（最多10个模板）、TTL过期（30分钟）、基于mtime的自动失效",
        "resource_cleanup": "显式Puppeteer页面清理，防止僵尸进程和内存泄漏"
      },
      "multi_agent_support": [
        "Claude Code",
        "OpenCode",
        "OpenClaw",
        "Hermes",
        "Trae"
      ]
    }
  },
  "install": {
    "global": "npm install -g @bytechain.cn/colamd-themes",
    "npx": "npx @bytechain.cn/colamd-themes <command>"
  },
  "config": {
    "default_themes_dir": "themes",
    "auto_match_default": true,
    "config_file": "~/.colamd-themes/config.json"
  },
  "commands": {
    "from-url": {
      "description": "从 URL 提取主题（含 SSRF 防护）",
      "usage": "colamd-themes from-url <URL> [options]",
      "options": {
        "-n, --name": "主题名称",
        "-o, --output": "输出 CSS 文件路径",
        "-d, --themes-dir": "主题输出目录",
        "-c, --color-system": "强制颜色系统 ID",
        "-m, --mermaid-preset": "强制 Mermaid 预设",
        "-A, --auto-match": "自动匹配配色和预设"
      }
    },
    "from-docx": {
      "description": "从 DOCX 文件提取主题",
      "usage": "colamd-themes from-docx <file.docx> [options]"
    },
    "from-pdf": {
      "description": "从 PDF 文件提取主题",
      "usage": "colamd-themes from-pdf <file.pdf> [options]"
    },
    "extract": {
      "description": "自动检测源类型并提取",
      "usage": "colamd-themes extract <source> [options]"
    },
    "export-html": {
      "description": "导出 Markdown 为 HTML（支持异步 I/O）",
      "usage": "colamd-themes export-html <input.md> -t <theme> -o <output.html>",
      "options": {
        "-t, --theme": "主题名称或 CSS 文件路径",
        "-o, --output": "输出文件路径"
      }
    },
    "export-pdf": {
      "description": "导出 Markdown 为 PDF（含资源清理优化）",
      "usage": "colamd-themes export-pdf <input.md> -t <theme> -o <output.pdf>",
      "options": {
        "-t, --theme": "主题名称或 CSS 文件路径",
        "-o, --output": "输出文件路径",
        "--format": "页面格式 (A4/Letter/A3)"
      }
    },
    "export": {
      "description": "批量导出多个文件（支持异步 I/O + 模板缓存）",
      "usage": "colamd-themes export <inputs...> --format html|pdf -t <theme> -d <dir>"
    },
    "set-theme": {
      "description": "管理主题配置",
      "usage": "colamd-themes set-theme <name> [--default|--css <file>|--remove]"
    },
    "list": {
      "description": "列出已生成的主题",
      "usage": "colamd-themes list [-d <dir>]"
    },
    "color-systems": {
      "description": "列出内置颜色系统（15套）",
      "usage": "colamd-themes color-systems [-j]"
    },
    "mermaid-presets": {
      "description": "列出 Mermaid 预设",
      "usage": "colamd-themes mermaid-presets [-j]"
    },
    "validate": {
      "description": "验证主题是否符合 v3.0 范式（含输入验证）",
      "usage": "colamd-themes validate <theme.css>"
    },
    "convert-skill": {
      "description": "转换为其他 AI Agent 技能格式",
      "usage": "colamd-themes convert-skill [--agent claude-code|opencode|openclaw|hermes|trae]",
      "options": {
        "--agent": "目标 Agent 类型"
      }
    }
  },
  "examples": [
    {
      "description": "全局安装后使用",
      "command": "npm install -g @bytechain.cn/colamd-themes && colamd-themes --version"
    },
    {
      "description": "使用 npx 按需运行（无需安装）",
      "command": "npx @bytechain.cn/colamd-themes color-systems"
    },
    {
      "description": "从 Word 文档提取并自动匹配配色",
      "command": "colamd-themes extract ./report.docx -n \"corporate\" -A"
    },
    {
      "description": "从网页提取并指定 Morandi 配色（含 SSRF 防护）",
      "command": "colamd-themes from-url https://example.com -n \"web-theme\" -c sage-green"
    },
    {
      "description": "导出为 HTML（异步 I/O 优化）",
      "command": "colamd-themes export-html doc.md -t elegant -o output.html"
    },
    {
      "description": "导出为 PDF（含 Puppeteer 资源清理）",
      "command": "colamd-themes export-pdf doc.md -t dark -o output.pdf"
    },
    {
      "description": "批量导出目录下所有 Markdown（模板缓存加速）",
      "command": "colamd-themes export docs/ --format pdf -t elegant -d output/"
    },
    {
      "description": "注册自定义主题并设为默认",
      "command": "colamd-themes set-theme my-brand --css themes/custom.css --default"
    },
    {
      "description": "验证主题合规性（含 CSS 大小验证 ≤1MB）",
      "command": "colamd-themes validate themes/my-theme.css"
    },
    {
      "description": "转换为 Claude Code 技能格式",
      "command": "colamd-themes convert-skill --agent claude-code"
    }
  ],
  "scripts": {
    "wrapper": "scripts/colamd-themes-wrapper.sh"
  },
  "supported_sources": [
    "url",
    "docx",
    "pdf"
  ],
  "output_formats": [
    "css",
    "html",
    "pdf"
  ],
  "built_in_themes": [
    "light",
    "dark",
    "elegant",
    "newsprint"
  ],
  "color_systems": {
    "morandi": [
      "morandi-pink",
      "morandi-green",
      "morandi-blue"
    ],
    "macaron": [
      "macaron-strawberry",
      "macaron-mint",
      "macaron-blueberry"
    ],
    "nordic": [
      "nordic-fjord-blue",
      "nordic-pine-green",
      "nordic-cloud-grey"
    ],
    "vintage": [
      "vintage-amber",
      "vintage-burgundy",
      "vintage-forest"
    ],
    "mint": [
      "mint-matcha",
      "mint-spearmint",
      "mint-seafoam"
    ]
  },
  "mermaid_presets": [
    "light",
    "dark",
    "elegant"
  ],
  "tags": [
    "colamd",
    "theme",
    "css",
    "markdown",
    "html",
    "pdf",
    "wcag",
    "typography",
    "mermaid",
    "security",
    "performance",
    "multi-agent"
  ]
}